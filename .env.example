# Energia Power LLC - Environment Variables
# Copy this file to .env and fill in your values

# Database
# If Postgres runs via this repo's docker-compose.yml, it is published on host port 5433 (not 5432).
DATABASE_URL="postgresql://energia:energia_dev_password@localhost:5433/energia_db"

# Inside the Docker app container only (hostname `postgres`, internal port 5432):
# DATABASE_URL="postgresql://energia:energia_dev_password@postgres:5432/energia_db"

# Native PostgreSQL on your machine (default port 5432):
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/energia_db"

# =============================================================================
# Google Workspace (Gmail, Drive, Contacts)
# =============================================================================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""           # or GOOGLE_CLIENT_ID_SECRET
GOOGLE_REDIRECT_URI="http://localhost:3001/api/gmail/callback"
GOOGLE_DRIVE_FOLDER_ID=""           # Root folder for bills/contracts
GOOGLE_DRIVE_BILLS_FOLDER_ID=""     # Subfolder for customer bills
GOOGLE_DRIVE_CONTRACTS_FOLDER_ID="" # Subfolder for contracts

# =============================================================================
# Market Data APIs (optional - for Module 5)
# =============================================================================
EIA_API_KEY=""   # https://www.eia.gov/opendata/ - free registration
NEWS_API_KEY=""  # https://newsapi.org/ - free tier available

# =============================================================================
# App
# =============================================================================
NEXT_PUBLIC_APP_URL="http://localhost:3001"
NODE_ENV="development"
