// Energia Power LLC - CRM & Brokerage Management
// Prisma Schema - PostgreSQL

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// DIRECTORY - Customers & Suppliers
// =============================================================================

// One unique entry per customer. Energy type (electric/natural gas) is on Contract, not here.
model Customer {
  id              String    @id @default(cuid())
  name            String
  email           String?
  phone           String?
  company         String?
  address         String?
  city            String?
  state           String?
  zip             String?
  notes           String?   @db.Text
  hasElectric     Boolean   @default(false) @map("has_electric")
  hasNaturalGas   Boolean   @default(false) @map("has_natural_gas")
  googleContactId String?   @map("google_contact_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  contracts        Contract[]
  contractWorkflowRows ContractWorkflowRow[]
  tasks            Task[]
  documents        Document[]
  rfpRequests      RfpRequest[]
  emails           Email[]          @relation("CustomerEmails")
  contacts         Contact[]
  calendarEvents   CalendarEvent[]

  @@map("customers")
}

model Supplier {
  id              String   @id @default(cuid())
  name            String
  email           String?
  phone           String?
  website         String?
  address         String?
  city            String?
  state           String?
  zip             String?
  notes           String?  @db.Text
  isElectric      Boolean  @default(false) @map("is_electric")
  isNaturalGas    Boolean  @default(false) @map("is_natural_gas")
  googleContactId String?  @map("google_contact_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  contacts       SupplierContact[]
  contactLinks   Contact[] @relation("SupplierContactLinks")
  contracts      Contract[]
  documents      Document[]
  rfpRequests    RfpRequest[] @relation("RfpSuppliers")
  rfpQuotes      RfpQuote[]
  emails         Email[]  @relation("SupplierEmails")

  @@map("suppliers")
}

model SupplierContact {
  id         String   @id @default(cuid())
  supplierId String   @map("supplier_id")
  name       String
  email      String?
  phone      String?
  role       String?
  isPrimary  Boolean  @default(false) @map("is_primary")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([supplierId, email])
  @@map("supplier_contacts")
}

// =============================================================================
// PROSPECTS (unconverted leads)
// =============================================================================

model Prospect {
  id                  String    @id @default(cuid())
  name                String
  email               String?
  phone               String?
  company             String?
  address             String?
  notes               String?   @db.Text
  hasElectric         Boolean   @default(false) @map("has_electric")
  hasNaturalGas       Boolean   @default(false) @map("has_natural_gas")
  convertedToCustomerId String?  @map("converted_to_customer_id")
  convertedAt         DateTime? @map("converted_at")
  googleContactId     String?   @map("google_contact_id")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  tasks Task[]

  @@map("prospects")
}

// =============================================================================
// CONTRACTS
// =============================================================================

enum EnergyType {
  ELECTRIC
  NATURAL_GAS
}

enum PriceUnit {
  KWH    // Kilowatt-hours (electric)
  MCF    // Thousand cubic feet (gas)
  CCF    // Hundred cubic feet (gas)
  DTH    // Dekatherm (gas)
}

model Contract {
  id               String     @id @default(cuid())
  customerId       String     @map("customer_id")
  supplierId       String     @map("supplier_id")
  mainContactId    String?    @map("main_contact_id")
  energyType       EnergyType @map("energy_type")
  priceUnit        PriceUnit  @map("price_unit")
  pricePerUnit     Decimal    @map("price_per_unit") @db.Decimal(10, 6) // e.g., $/KWH or $/MCF
  startDate        DateTime   @map("start_date") @db.Date
  expirationDate   DateTime   @map("expiration_date") @db.Date
  termMonths       Int        @map("term_months")
  annualUsage      Decimal?   @map("annual_usage") @db.Decimal(14, 2)   // KWH or MCF/CCF
  avgMonthlyUsage  Decimal?   @map("avg_monthly_usage") @db.Decimal(14, 2)
  contractIncome   Decimal?   @map("contract_income") @db.Decimal(12, 2)  // Total expected income
  brokerMargin     Decimal?   @map("broker_margin") @db.Decimal(10, 6)   // Per-unit margin
  customerUtility  String?    @map("customer_utility")
  signedDate       DateTime?  @map("signed_date") @db.Date
  totalMeters      Int?       @map("total_meters")
  status           String     @default("active") // active, archived, cancelled, pending
  notes            String?    @db.Text
  /// Google Drive (or similar) link to the executed/signed customer contract PDF/PNG.
  signedContractDriveUrl String? @map("signed_contract_drive_url") @db.Text
  /// Set when a renewal reminder is sent from Energia (e.g. Send renewal email).
  renewalReminderSentAt  DateTime? @map("renewal_reminder_sent_at")
  /// When set, this contract was created automatically when an RFP was archived (id is opaque reference only).
  sourceRfpRequestId     String?   @map("source_rfp_request_id")
  /// True for RFP-sourced stubs until the broker enters executed terms (rate, supplier, dates) from the counter-signed agreement.
  needsContractDetail    Boolean   @default(false) @map("needs_contract_detail")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  customer          Customer          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  supplier          Supplier         @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  mainContact       Contact?         @relation(fields: [mainContactId], references: [id], onDelete: SetNull)
  commissionPayments CommissionPayment[]
  documents         Document[]
  rfpQuotes         RfpQuote[]
  calendarEvents    CalendarEvent[]
  accounts          ContractAccount[]
  tasks             Task[]            @relation("TaskContract")
  workflowRow       ContractWorkflowRow?

  @@map("contracts")
}

/// Broker renewal / new-business pipeline (one row per active contract or standalone customer pursuit).
model ContractWorkflowRow {
  id String @id @default(cuid())
  /// Set for renewal rows tied to a directory contract (unique when present).
  contractId String? @unique @map("contract_id")
  /// For new-business rows before a contract exists.
  customerId String? @map("customer_id")
  energyType EnergyType? @map("energy_type")
  displayLabel String? @map("display_label")

  workflowArchived   Boolean   @default(false) @map("workflow_archived")
  workflowArchivedAt DateTime? @map("workflow_archived_at")

  receivedBillsAt DateTime? @map("received_bills_at")
  rfpQuoteClosedAt    DateTime? @map("rfp_quote_closed_at")
  newContractAmendedAt DateTime? @map("new_contract_amended_at")

  /// Latest RFP tied to this pursuit (sent / quotes / archive).
  linkedRfpRequestId String? @unique @map("linked_rfp_request_id")

  /// blank | end_pursuit | refresh_rfp
  contractOutcome String @default("") @map("contract_outcome")

  /// When set, RFP/quote checks ignore linked RFP activity at or before this time (workflow “rewind”).
  lastWorkflowRefreshAt DateTime? @map("last_workflow_refresh_at")

  /// User marked renewal reminder as not applicable (no prior contract / no email needed).
  renewalReminderNotApplicableAt DateTime? @map("renewal_reminder_not_applicable_at")
  /// Manual “RFP sent” when linking or timestamps are insufficient.
  rfpSentOverrideAt DateTime? @map("rfp_sent_override_at")
  /// Manual “quote summary sent” override for the linked RFP.
  quoteSummaryOverrideAt DateTime? @map("quote_summary_override_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  contract  Contract?   @relation(fields: [contractId], references: [id], onDelete: SetNull)
  customer  Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  linkedRfp RfpRequest? @relation("ContractWorkflowRfp", fields: [linkedRfpRequestId], references: [id], onDelete: SetNull)

  @@index([workflowArchived])
  @@map("contract_workflow_rows")
}

/// Utility / billing accounts tied to a contract (renewal emails, customer communications).
model ContractAccount {
  id               String   @id @default(cuid())
  contractId       String   @map("contract_id")
  accountId        String   @map("account_id")
  serviceAddress   String?  @map("service_address") @db.Text
  annualUsage      Decimal? @map("annual_usage") @db.Decimal(14, 2)
  avgMonthlyUsage  Decimal? @map("avg_monthly_usage") @db.Decimal(14, 2)
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@map("contract_accounts")
}

model CommissionPayment {
  id          String    @id @default(cuid())
  contractId  String    @map("contract_id")
  amount      Decimal   @db.Decimal(12, 2)
  paymentDate DateTime @map("payment_date") @db.Date
  source      String    // "email" | "portal" | "manual"
  reference   String?   // Email subject, invoice #, etc.
  notes       String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@map("commission_payments")
}

// =============================================================================
// TASKS / PROSPECTING
// =============================================================================

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskType {
  TASK
  NOTE
  PROSPECT
}

model TaskList {
  id           String   @id @default(cuid())
  name         String
  sortOrder    Int      @default(0) @map("sort_order")
  googleListId String?  @map("google_list_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tasks Task[]

  @@map("task_lists")
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?    @db.Text
  type        TaskType   @default(TASK)
  status      TaskStatus @default(PENDING)
  dueDate     DateTime?  @map("due_date") @db.Date
  dueAt       DateTime?  @map("due_at")
  allDay      Boolean    @default(false) @map("all_day")
  starred     Boolean    @default(false)
  repeatRule  String?    @map("repeat_rule") @db.Text
  googleTaskId String?   @map("google_task_id")
  priority    Int        @default(0)
  listSortOrder Int      @default(0) @map("list_sort_order")
  customerId  String?    @map("customer_id")
  prospectId  String?    @map("prospect_id")
  contactId   String?    @map("contact_id")
  contractId  String?    @map("contract_id")
  taskListId  String?    @map("task_list_id")
  completedAt DateTime?  @map("completed_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  customer Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  prospect Prospect? @relation(fields: [prospectId], references: [id], onDelete: SetNull)
  contact  Contact?   @relation("TaskContact", fields: [contactId], references: [id], onDelete: SetNull)
  linkedContract Contract? @relation("TaskContract", fields: [contractId], references: [id], onDelete: SetNull)
  taskList TaskList?   @relation(fields: [taskListId], references: [id], onDelete: SetNull)
  calendarEvents CalendarEvent[]

  @@index([taskListId])
  @@index([contactId])
  @@index([contractId])
  @@index([dueDate])
  @@index([dueAt])
  @@map("tasks")
}

// =============================================================================
// DOCUMENTS (Google Drive integration)
// =============================================================================

enum DocumentType {
  BILL
  CONTRACT
  RFP
  SPREADSHEET
  OTHER
}

model Document {
  id           String       @id @default(cuid())
  name         String
  type         DocumentType @default(OTHER)
  googleDriveId String?     @map("google_drive_id")
  googleDriveUrl String?    @map("google_drive_url")
  mimeType     String?      @map("mime_type")
  fileSize     Int?         @map("file_size")
  sourceEmail  String?      @map("source_email")
  customerId   String?      @map("customer_id")
  supplierId   String?      @map("supplier_id")
  contractId   String?      @map("contract_id")
  uploadedAt   DateTime     @default(now()) @map("uploaded_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  customer Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  supplier Supplier?  @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  contract Contract?  @relation(fields: [contractId], references: [id], onDelete: SetNull)

  @@map("documents")
}

// =============================================================================
// SCHEDULER / CALENDAR
// =============================================================================

enum CalendarEventType {
  CONTRACT_RENEWAL
  LICENSE_EXPIRY
  RFP_DEADLINE
  /// Shown when an RFP is sent — supplier quote due (distinct calendar styling).
  SUPPLIER_QUOTE_DUE_RFP
  FOLLOW_UP
  MEETING
  TASK
  OTHER
}

model CalendarEvent {
  id          String            @id @default(cuid())
  title       String
  description String?           @db.Text
  startAt     DateTime          @map("start_at")
  endAt       DateTime?         @map("end_at")
  allDay      Boolean           @default(false) @map("all_day")
  eventType   CalendarEventType @default(OTHER) @map("event_type")
  /// Set when this row is linked to a Google Calendar event (primary calendar). Used for sync.
  googleEventId String?         @unique @map("google_event_id")

  customerId   String? @map("customer_id")
  contactId    String? @map("contact_id")
  contractId   String? @map("contract_id")
  taskId       String? @map("task_id")
  licenseId    String? @map("license_id")
  rfpRequestId String? @map("rfp_request_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  customer   Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  contact    Contact?    @relation(fields: [contactId], references: [id], onDelete: SetNull)
  contract   Contract?   @relation(fields: [contractId], references: [id], onDelete: SetNull)
  task       Task?       @relation(fields: [taskId], references: [id], onDelete: SetNull)
  license    License?    @relation(fields: [licenseId], references: [id], onDelete: SetNull)
  rfpRequest RfpRequest? @relation(fields: [rfpRequestId], references: [id], onDelete: SetNull)

  @@index([startAt])
  @@map("calendar_events")
}

// =============================================================================
// LICENSES (CRNGS, CRES - 2-year expiration from issue)
// =============================================================================

enum LicenseType {
  CRNGS  // Natural Gas
  CRES   // Electric
}

model License {
  id             String     @id @default(cuid())
  licenseType    LicenseType @map("license_type")
  licenseNumber  String     @map("license_number")
  state          String?
  issueDate      DateTime   @map("issue_date") @db.Date
  expirationDate DateTime   @map("expiration_date") @db.Date // Auto-calculated: issueDate + 2 years
  status         String     @default("active") // active, expired, suspended
  notes          String?    @db.Text
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  calendarEvents CalendarEvent[]

  @@map("licenses")
}

// =============================================================================
// RFP (Request for Pricing) Workflow
// =============================================================================

model RfpRequest {
  id               String     @id @default(cuid())
  /// Optional when the RFP uses directory company + contact only (no CRM Customer row yet).
  customerId       String?    @map("customer_id")
  energyType       EnergyType @map("energy_type")
  annualUsage      Decimal?   @map("annual_usage") @db.Decimal(14, 2)
  avgMonthlyUsage  Decimal?   @map("avg_monthly_usage") @db.Decimal(14, 2)
  billDocumentId   String?    @map("bill_document_id")
  termMonths       Int?       @map("term_months")
  googleDriveFolderUrl  String?  @map("google_drive_folder_url") @db.Text
  /// Multiple bill PDFs from Google Drive: JSON array of { fileId?, webViewLink, filename? }.
  billDriveItems        Json?    @map("bill_drive_items")
  /// Electric RFP only: { selectedIds: string[], fixedRateCapacityAdjustNote?: string }.
  electricPricingOptions Json?   @map("electric_pricing_options")
  summarySpreadsheetUrl String?  @map("summary_spreadsheet_url") @db.Text
  quoteDueDate          DateTime? @map("quote_due_date") @db.Date
  contractStartMonth    Int?      @map("contract_start_month")
  contractStartYear     Int?      @map("contract_start_year")
  brokerMargin          Decimal?  @map("broker_margin") @db.Decimal(10, 6)
  brokerMarginUnit      PriceUnit? @map("broker_margin_unit")
  ldcUtility            String?   @map("ldc_utility")
  requestedTerms        Json?     @map("requested_terms")
  /// Map of supplierId -> contact id chosen for RFP send (draft/resume).
  supplierContactSelections Json? @map("supplier_contact_selections")
  customerContactId     String?   @map("customer_contact_id")
  /// Additional customer-side contacts to include when sending quote summaries (JSON array of contact ids).
  quoteSummaryCcContactIds Json?  @map("quote_summary_cc_contact_ids")
  /// Customer contact ids selected for quote summary distribution (native PG array).
  quoteSummaryContactIds String[] @default([]) @map("quote_summary_contact_ids")
  quoteSummarySentAt DateTime?  @map("quote_summary_sent_at")
  sentAt           DateTime?  @map("sent_at")
  status           String     @default("draft") // draft, sent, quotes_received
  notes            String?    @db.Text
  /// Enrollment / contract-timing context (JSON): cycle ID, SDI, transition type, meter read fallbacks, etc.
  enrollmentDetails Json?     @map("enrollment_details")
  /// When this row was created by re-issuing supplier emails for an earlier request, links to that parent.
  parentRfpId      String?    @map("parent_rfp_id")
  /// 0 = original supplier send, 1 = first refresh/re-issue, etc.
  refreshSequence  Int        @default(0) @map("refresh_sequence")
  /// When set, hidden from default Recent RFPs lists (history / closed deals).
  archivedAt       DateTime?  @map("archived_at")
  /// Snapshot of quote comparison picks/manual rows when archived (JSON). See `QuoteWorkspaceSnapshot` usage in app.
  archivedQuoteWorkspace Json? @map("archived_quote_workspace")
  /// Saved term → pick for quote comparison (keys: term months as string). See quotes workspace save/load.
  quoteComparisonPicks Json? @map("quote_comparison_picks")
  /// Draft for the customer quote email on the Quotes workspace compose tab (to, cc, subject, html, template, flags).
  customerQuoteEmailDraft Json? @map("customer_quote_email_draft")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  customer         Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerContact  Contact?         @relation("RfpCustomerContact", fields: [customerContactId], references: [id], onDelete: SetNull)
  parentRfp        RfpRequest?      @relation("RfpReissueChain", fields: [parentRfpId], references: [id], onDelete: SetNull)
  childReissues    RfpRequest[]     @relation("RfpReissueChain")
  suppliers        Supplier[]       @relation("RfpSuppliers")
  quotes           RfpQuote[]       @relation("RfpQuoteToRequest")
  accountLines     RfpAccountLine[]
  calendarEvents   CalendarEvent[]
  contractWorkflowLink ContractWorkflowRow? @relation("ContractWorkflowRfp")

  @@index([parentRfpId])
  @@map("rfp_requests")
}

model RfpAccountLine {
  id              String   @id @default(cuid())
  rfpRequestId    String   @map("rfp_request_id")
  accountNumber   String   @map("account_number")
  serviceAddress  String?  @map("service_address") @db.Text
  annualUsage     Decimal  @map("annual_usage") @db.Decimal(14, 2)
  avgMonthlyUsage Decimal  @map("avg_monthly_usage") @db.Decimal(14, 2)
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")

  rfpRequest RfpRequest @relation(fields: [rfpRequestId], references: [id], onDelete: Cascade)

  @@index([rfpRequestId])
  @@map("rfp_account_lines")
}

model RfpQuote {
  id             String     @id @default(cuid())
  rfpRequestId   String?    @map("rfp_request_id")
  rfpRequest     RfpRequest? @relation("RfpQuoteToRequest", fields: [rfpRequestId], references: [id], onDelete: SetNull)
  supplierId     String     @map("supplier_id")
  contractId     String?    @map("contract_id")
  rate           Decimal    @db.Decimal(10, 6)
  priceUnit      PriceUnit  @map("price_unit")
  termMonths     Int        @map("term_months")
  brokerMargin   Decimal?   @map("broker_margin") @db.Decimal(10, 6)
  totalMargin    Decimal?   @map("total_margin") @db.Decimal(12, 2)
  estimatedContractValue Decimal? @map("estimated_contract_value") @db.Decimal(14, 2)
  isBestOffer    Boolean    @default(false) @map("is_best_offer")
  sourceEmailId  String?    @map("source_email_id")
  receivedAt     DateTime   @default(now()) @map("received_at")
  notes          String?    @db.Text
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  contract Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)

  @@map("rfp_quotes")
}

// =============================================================================
// COMMUNICATION HUB - Contacts
// =============================================================================

model Contact {
  id                 String    @id @default(cuid())
  firstName          String?   @map("first_name")
  lastName           String?   @map("last_name")
  name               String    // Display name
  email              String?   // Legacy / primary for display
  phone              String?   // Legacy / primary for display
  company            String?
  isPriority         Boolean   @default(false) @map("is_priority")
  jobTitle           String?   @map("job_title")
  label              String?
  website            String?
  notes              String?   @db.Text
  source             String    @default("local") // local | google
  googleResourceName String?   @map("google_resource_name")
  addedToContactsAt  DateTime? @map("added_to_contacts_at")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  customerId         String?   @map("customer_id")
  supplierId         String?   @map("supplier_id")

  emails             ContactEmail[]
  phones             ContactPhone[]
  addresses          ContactAddress[]
  significantDates   ContactSignificantDate[]
  relatedPersons     ContactRelatedPerson[]
  contractsAsMain    Contract[]

  customer           Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  supplier           Supplier? @relation("SupplierContactLinks", fields: [supplierId], references: [id], onDelete: SetNull)
  calendarEvents     CalendarEvent[]
  rfpRequestsAsCustomerContact RfpRequest[] @relation("RfpCustomerContact")
  tasks                        Task[]       @relation("TaskContact")

  @@map("contacts")
}

/// Queued when a local Contact is deleted but had `googleResourceName` — removed from Google on next POST /api/contacts/sync.
model GoogleContactDeletionQueue {
  id                 String   @id @default(cuid())
  googleResourceName String   @unique @map("google_resource_name")
  createdAt          DateTime @default(now()) @map("created_at")

  @@map("google_contact_deletion_queue")
}

model ContactEmail {
  id        String  @id @default(cuid())
  contactId String  @map("contact_id")
  email     String
  type      String? // work, home, other
  order     Int     @default(0)

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@map("contact_emails")
}

model ContactPhone {
  id        String  @id @default(cuid())
  contactId String  @map("contact_id")
  phone     String
  extension String? @db.Text
  type      String? // work, home, mobile, fax, other
  order     Int     @default(0)

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@map("contact_phones")
}

model ContactAddress {
  id        String  @id @default(cuid())
  contactId String  @map("contact_id")
  street    String?
  city      String?
  state     String?
  zip       String?
  type      String? // work, home, other
  order     Int     @default(0)

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@map("contact_addresses")
}

model ContactSignificantDate {
  id        String   @id @default(cuid())
  contactId String   @map("contact_id")
  label     String   // e.g. "Contract Expiration"
  date      DateTime @db.Date
  order     Int      @default(0)

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@map("contact_significant_dates")
}

model ContactRelatedPerson {
  id        String @id @default(cuid())
  contactId String @map("contact_id")
  name      String
  relation  String? // e.g. "Manager", "Assistant"
  order     Int    @default(0)

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@map("contact_related_persons")
}

// =============================================================================
// COMMUNICATION HUB - Emails
// =============================================================================

enum EmailDirection {
  INBOUND
  OUTBOUND
}

model Email {
  id           String        @id @default(cuid())
  messageId    String?       @map("message_id") @unique // Gmail message ID
  threadId     String?       @map("thread_id")
  direction    EmailDirection
  subject      String?
  body         String?       @db.Text
  bodyHtml     String?       @map("body_html") @db.Text
  fromAddress  String        @map("from_address")
  toAddresses  String[]      @map("to_addresses")
  ccAddresses  String[]      @map("cc_addresses")
  sentAt       DateTime      @map("sent_at")
  receivedAt   DateTime?     @map("received_at")
  customerId   String?       @map("customer_id")
  supplierId   String?       @map("supplier_id")
  isRead       Boolean       @default(false) @map("is_read")
  isRfp        Boolean       @default(false) @map("is_rfp")
  isRfpResponse Boolean      @default(false) @map("is_rfp_response")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  customer Customer? @relation("CustomerEmails", fields: [customerId], references: [id], onDelete: SetNull)
  supplier Supplier? @relation("SupplierEmails", fields: [supplierId], references: [id], onDelete: SetNull)

  @@map("emails")
}
