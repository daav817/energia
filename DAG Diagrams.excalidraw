    {
      "id": "HsA3_zylZc-ljaLP0Gx4p",
      "type": "text",
      "x": 27348.61297114201,
      "y": 2824.7324869162303,
      "width": 1328.197998046875,
      "height": 75,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#ffec99",
