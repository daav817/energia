    {
      "id": "wrOKojYfpi-cmukvsYipA",
      "type": "text",
      "x": 29201.535253992,
      "y": 2331.129956509773,
      "width": 1468.4979248046875,
      "height": 275,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
