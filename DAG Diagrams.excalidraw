      "seed": 35302425,
      "version": 530,
      "versionNonce": 592329657,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775754778823,
      "link": null,
      "locked": false,
      "text": "When the user clicks a given field, this field will highlight and calculate the value at the bottom of the column.  This will be a Total Calculated \nValue for the contract based on RFP Annual usage (which will need to be rendered as monthly usage for this calculation), the rate, and the number \nof term months.,  These highlighted amounts and calculations will be used in the Quote Email when the user click the \"Insert Quotes Table\"",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "When the user clicks a given field, this field will highlight and calculate the value at the bottom of the column.  This will be a Total Calculated \nValue for the contract based on RFP Annual usage (which will need to be rendered as monthly usage for this calculation), the rate, and the number \nof term months.,  These highlighted amounts and calculations will be used in the Quote Email when the user click the \"Insert Quotes Table\"",
      "autoResize": true,
      "lineHeight": 1.25
    },
