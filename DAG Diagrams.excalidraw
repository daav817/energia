      "seed": 254896471,
      "version": 375,
      "versionNonce": 244480889,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775754487213,
      "link": null,
      "locked": false,
      "text": "This tabbed section will be similar to the \"Compose Email\" functionality and UI as we have elsewhere in the program. \nIt will have the From/To/Cc/Bcc, the subject prepopulated with the what was set up in the email template, and an editor \nwith all the rich text contols.  \n\nIt will also have an \"Insert Quotes Table\" button.  When clicking this button, a table will \nbe inserted which will have several column: Contract Term (a row for as many terms available), Best Rate with the appropriate energy unit type, the supplier,  Total\ncontract value (the chosen proposed rate multiplied by the number of months multiplied by the RFP annual usage divided by 12), \nestimated monthly energy value.  Each row of this table will contain the appropriate data  for a given contract term\nas selected in the table from the \"Quote Comparison\" tab.\n\nThe Term Lengths fields will also include a monthly/year display underneath the term length itself.  For example:  \"12 month (Dec '26 to Nov '27)\"",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "jSI0r2lLutk0YboAgltV9",
      "originalText": "This tabbed section will be similar to the \"Compose Email\" functionality and UI as we have elsewhere in the program. \nIt will have the From/To/Cc/Bcc, the subject prepopulated with the what was set up in the email template, and an editor \nwith all the rich text contols.  \n\nIt will also have an \"Insert Quotes Table\" button.  When clicking this button, a table will \nbe inserted which will have several column: Contract Term (a row for as many terms available), Best Rate with the appropriate energy unit type, the supplier,  Total contract value (the chosen proposed rate multiplied by the number of months multiplied by the RFP annual usage divided by 12), \nestimated monthly energy value.  Each row of this table will contain the appropriate data  for a given contract term\nas selected in the table from the \"Quote Comparison\" tab.\n\nThe Term Lengths fields will also include a monthly/year display underneath the term length itself.  For example:  \"12 month (Dec '26 to Nov '27)\"",
      "autoResize": true,
      "lineHeight": 1.25
    },
